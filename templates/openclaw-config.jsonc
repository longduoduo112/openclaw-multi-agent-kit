// openclaw-config.jsonc — Template configuration snippet
// Copy relevant sections into your openclaw.json
// Replace all YOUR_* placeholders with actual values

{
  // Agent defaults — applied to all agents unless overridden
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": [
          "anthropic/claude-haiku-4-5"
        ]
      },
      "workspace": "/home/YOUR_USER/.openclaw/workspace",
      "maxConcurrent": 4
    }
  },

  // Skills system (v2026.3.24+) — one-click install, ClawHub marketplace
  "skills": {
    "enabled": true
  },

  // Telegram channel config
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "streaming": "off"
    }
  },

  // ACP / ACPX — coding agent backend via Agent Client Protocol
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "claude",
    "allowedAgents": ["claude", "codex", "opencode", "gemini", "pi"]
  },

  // Messages config
  "messages": {
    "ackReactionScope": "group-mentions"
  },

  // Session config
  "session": {
    "dmScope": "per-channel-peer",
    // Thread bindings — persistent sessions per topic/thread
    "threadBindings": {
      "enabled": true,
      "idleHours": 48,
      "maxAgeHours": 0
    }
  },

  // Hooks for boot files, memory, etc.
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "bootstrap-extra-files": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  }
}
